#!/usr/bin/env bash
# direnv configuration file
# This file is safe to commit to source control
# Learn more at: https://direnv.net/

echo "🔧 Loading JWT Paradigms project environment..."

# Check if .env exists
if [ ! -f .env ]; then
    echo "⚠️  Missing .env file!"
    echo ""
    echo "📋 Required environment variables:"
    echo "   - GEMINI_API_KEY: For generating persona headshots"
    echo ""
    echo "🚀 Quick setup:"
    echo "   cp .env.example .env"
    echo "   # Then edit .env to add your API keys"
    echo ""
    echo "📚 Get your Gemini API key at:"
    echo "   https://makersuite.google.com/app/apikey"
    echo ""
    echo "⏸️  Skipping environment loading until .env is configured"
else
    # Source the .env file
    echo "✅ Loading environment variables from .env"
    dotenv
    
    # Verify critical environment variables
    if [ -z "$GEMINI_API_KEY" ] || [ "$GEMINI_API_KEY" = "your-gemini-api-key-here" ]; then
        echo "⚠️  GEMINI_API_KEY not configured in .env"
        echo "   Persona headshot generation will not work"
    else
        echo "✅ GEMINI_API_KEY configured"
    fi
fi

# Project-specific setup
export PROJECT_ROOT="$(pwd)"
export PYTHONPATH="${PROJECT_ROOT}:${PYTHONPATH}"

echo "📁 Project root: $PROJECT_ROOT"

# Check for common development tools
if command -v make >/dev/null 2>&1; then
    echo "✅ make available - try 'make help' for project commands"
fi

if command -v python3 >/dev/null 2>&1; then
    echo "✅ python3 available"
fi

if command -v node >/dev/null 2>&1; then
    echo "✅ node available"
fi

if command -v cargo >/dev/null 2>&1; then
    echo "✅ cargo available for Rust examples"
fi

echo ""
echo "🎯 JWT Paradigms project environment loaded!"
echo "   Try 'make examples' to extract code examples from org files"
echo ""